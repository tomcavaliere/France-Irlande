rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /photos/{date}/{id} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    match /videos/{date}/{id} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 200 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
  }
}
