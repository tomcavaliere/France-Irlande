{
  "rules": {
    "current": {
      ".read": true,
      ".write": "auth != null",
      ".validate": "newData.hasChildren(['lat','lon','kmTotal','date','ts'])"
    },
    "stages": {
      ".read": true,
      "$date": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['lat','lon','kmTotal'])"
      }
    },
    "journals": {
      ".read": true,
      "$date": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 5000)"
      }
    },
    "photos": {
      ".read": true,
      "$date": {
        "$id": {
          ".write": "auth != null",
          ".validate": "newData.isString() && newData.val().length < 500000"
        }
      }
    },
    "comments": {
      ".read": true,
      "$date": {
        ".validate": "root.child('stages').child($date).exists()",
        "$id": {
          ".write": "!data.exists() || auth != null",
          ".validate": "newData.hasChildren(['text', 'name', 'ts'])",
          "text": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 500"
          },
          "name": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length < 30"
          },
          "ts": {
            ".validate": "newData.isNumber()"
          },
          "$other": { ".validate": false }
        }
      }
    },
    "bravos": {
      ".read": true,
      "$date": {
        ".validate": "root.child('stages').child($date).exists()",
        "$visitorId": {
          ".write": "!data.exists()",
          ".validate": "newData.val() === true"
        }
      }
    },
    "expenses": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
