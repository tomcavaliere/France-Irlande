{
  "rules": {
    "current": {
      ".read": true,
      ".write": "auth != null",
      ".validate": "newData.hasChildren(['lat','lon','kmTotal','date','ts'])"
    },
    "stages": {
      ".read": true,
      "$date": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['lat','lon','kmTotal'])"
      }
    },
    "journals": {
      ".read": true,
      "$date": {
        ".write": "auth != null",
        ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 5000)"
      }
    },
    "photos": {
      ".read": true,
      "$date": {
        "$id": {
          ".write": "auth != null",
          ".validate": "newData.isString() && newData.val().length < 500000"
        }
      }
    },
    "videos": {
      ".read": true,
      "$date": {
        "$id": {
          ".write": "auth != null",
          ".validate": "newData.isString() && newData.val().length < 500 && newData.val().matches(/^https:\\/\\/firebasestorage\\.googleapis\\.com\\/.*$/)"
        }
      }
    },
    "comments": {
      ".read": true,
      "$date": {
        ".validate": "root.child('stages').child($date).exists()",
        "$id": {
          ".write": "!data.exists() || auth != null",
          ".validate": "newData.hasChildren(['text', 'name', 'ts'])",
          "text": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500"
          },
          "name": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
          },
          "ts": {
            ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= (now + 60000)"
          },
          "$other": { ".validate": false }
        }
      }
    },
    "bravos": {
      ".read": true,
      "$date": {
        ".validate": "root.child('stages').child($date).exists()",
        "$visitorId": {
          ".write": "!data.exists()",
          ".validate": "newData.val() === true"
        }
      }
    },
    "tracks": {
      ".read": true,
      "$date": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['coords','kmDay','ts'])"
      }
    },
    "expenses": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$id": {
        ".validate": "newData.hasChildren(['amount','cat','date','ts'])",
        "amount": {
          ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() < 10000"
        },
        "cat": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        },
        "date": {
          ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)"
        },
        "ts": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "desc": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "$other": { ".validate": false }
      }
    }
  }
}
